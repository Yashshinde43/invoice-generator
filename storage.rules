rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to read and write expense receipts
    match /expenses/{businessId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write invoice files
    match /invoices/{businessId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write business files
    match /business/{businessId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write profile pictures
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default rule - deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
